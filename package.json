{
  "name": "cold-email-campaign",
  "version": "1.0.0",
  "description": "Automated cold email campaign system with Gmail API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "campaign": "ts-node src/index.ts",
    "campaign:dry-run": "ts-node src/index.ts --dry-run",
    "generate": "ts-node src/campaign/generation-runner.ts",
    "send": "ts-node src/campaign/send-runner.ts",
    "send:dry-run": "ts-node src/campaign/send-runner.ts --dry-run",
    "check-replies": "ts-node src/campaign/reply-checker.ts",
    "check-replies:dry-run": "ts-node src/campaign/reply-checker.ts --dry-run",
    "auth-setup": "ts-node scripts/auth-setup.ts"
  },
  "keywords": [
    "email",
    "campaign",
    "gmail",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.2.3",
    "googleapis": "^170.1.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
